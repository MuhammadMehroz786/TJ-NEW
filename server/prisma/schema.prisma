generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  SALLA
  SHOPIFY
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  PENDING
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum UserRole {
  MERCHANT
  CREATOR
  ADMIN
}

enum CampaignStatus {
  PENDING
  ACCEPTED
  DECLINED
  IN_PROGRESS
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
  COMPLETED
}

enum PaymentStatus {
  HELD
  RELEASED
  REFUNDED
}

enum CreditPurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(MERCHANT)
  aiCredits        Int      @default(30)
  aiCreditsWeekKey String   @default("")
  purchasedCredits Int      @default(0)
  language         String   @default("en")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  marketplaceConnections MarketplaceConnection[]
  products               Product[]
  creatorProfile         CreatorProfile?
  merchantCampaigns      Campaign[]              @relation("MerchantCampaigns")
  creatorCampaigns       Campaign[]              @relation("CreatorCampaigns")
  promoCodes             PromoCode[]
  affiliateLinks         AffiliateLink[]
  merchantSales          ManualSale[]            @relation("MerchantSales")
  creatorSales           ManualSale[]            @relation("CreatorSales")
  aiStudioImages         AiStudioImage[]
  aiStudioFolders        AiStudioFolder[]
  whatsappSessions       WhatsAppSession[]
  creditPurchases        CreditPurchase[]
  passwordResetTokens    PasswordResetToken[]
  aiCreditCodeRedemptions AiCreditCodeRedemption[]
}

model CreatorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  displayName     String
  bio             String?  @db.Text
  profilePhoto    String?
  niche           String
  rate            Decimal  @db.Decimal(10, 2)
  socialPlatforms Json     @default("[]")
  portfolioLinks  Json     @default("[]")
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String         @id @default(uuid())
  merchantId   String
  creatorId    String
  productId    String
  status       CampaignStatus @default(PENDING)
  brief        String         @db.Text
  amount       Decimal        @db.Decimal(10, 2)
  socialLinks  Json           @default("[]")
  revisionNote String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  merchant User    @relation("MerchantCampaigns", fields: [merchantId], references: [id], onDelete: Cascade)
  creator  User    @relation("CreatorCampaigns", fields: [creatorId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  payment  Payment?
}

model Payment {
  id         String        @id @default(uuid())
  campaignId String        @unique
  amount     Decimal       @db.Decimal(10, 2)
  status     PaymentStatus @default(HELD)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id          String   @id @default(uuid())
  merchantId  String
  code        String
  description String?
  discount    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant User @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, code])
}

model AffiliateLink {
  id        String   @id @default(uuid())
  creatorId String
  productId String
  slug      String   @unique
  targetUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  product Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  clicks  Click[]

  @@unique([creatorId, productId])
}

model Click {
  id              String   @id @default(uuid())
  affiliateLinkId String
  ip              String?
  userAgent       String?
  referer         String?
  createdAt       DateTime @default(now())

  affiliateLink AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)
}

model ManualSale {
  id         String   @id @default(uuid())
  merchantId String
  creatorId  String
  productId  String?
  orderId    String?
  amount     Decimal  @db.Decimal(10, 2)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant User    @relation("MerchantSales", fields: [merchantId], references: [id], onDelete: Cascade)
  creator  User    @relation("CreatorSales", fields: [creatorId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model MarketplaceConnection {
  id             String           @id @default(uuid())
  userId         String
  platform       Platform
  storeName      String
  storeUrl       String
  accessToken    String
  refreshToken   String?
  clientId       String?
  clientSecret   String?
  tokenExpiresAt DateTime?
  status         ConnectionStatus @default(CONNECTED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([userId, storeUrl])
}

model Product {
  id                      String        @id @default(uuid())
  userId                  String
  marketplaceConnectionId String?
  title                   String        @db.VarChar(255)
  description             String?       @db.Text
  price                   Decimal       @db.Decimal(10, 2)
  compareAtPrice          Decimal?      @db.Decimal(10, 2)
  sku                     String?
  barcode                 String?
  currency                String        @default("SAR")
  quantity                Int           @default(0)
  images                  Json          @default("[]")
  category                String?
  productType             String?
  vendor                  String?
  tags                    Json          @default("[]")
  weight                  Decimal?      @db.Decimal(10, 2)
  weightUnit              String?       @default("kg")
  status                  ProductStatus @default(DRAFT)
  platformProductId       String?
  platformData            Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplaceConnection MarketplaceConnection? @relation(fields: [marketplaceConnectionId], references: [id], onDelete: SetNull)
  campaigns             Campaign[]
  affiliateLinks        AffiliateLink[]
  manualSales           ManualSale[]

  @@unique([sku, userId])
}

model AiStudioImage {
  id        String   @id @default(uuid())
  userId    String
  folderId  String?
  imagePath String
  imageUrl  String
  background String  @default("studio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder AiStudioFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([folderId])
}

model AiStudioFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  images AiStudioImage[]

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model WhatsAppSession {
  id                 String    @id @default(uuid())
  phoneNumber        String    @unique
  userId             String?
  creditsUsed        Int       @default(0)
  creditsLimit       Int       @default(5)
  isVerified         Boolean   @default(false)
  state              String    @default("idle")
  emailAttempts      Int       @default(0)
  pendingEmail       String?
  emailOtpHash       String?
  emailOtpExpiresAt  DateTime?
  otpAttempts        Int       @default(0)
  pendingTheme       String?
  pendingImageIds    String[]  @default([])
  language           String    @default("en")
  lastSourceImage    String?   @db.Text
  lastSourceMimeType String?
  lastMessageAt      DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  enhancements WhatsAppEnhancement[]

  @@index([state, lastMessageAt])
  @@index([userId])
}

// Tracks every enhancement the bot sent to a merchant, keyed by the outbound
// WhatsApp message ID. When the user replies (quotes) that image, we look up
// the original source to refine against.
model WhatsAppEnhancement {
  id              String   @id @default(uuid())
  sessionId       String
  outboundWamid   String   @unique
  sourceImage     String   @db.Text
  sourceMimeType  String
  createdAt       DateTime @default(now())

  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// Signup OTP flow. Before a real User row is created, we park the submitted
// credentials here with a 6-digit email-verification code. Verified rows are
// deleted (User row created elsewhere); expired/abandoned ones are cleaned up
// by TTL or on next signup attempt for the same email.
model PendingSignup {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  name              String
  role              UserRole @default(MERCHANT)
  otpHash           String
  otpExpiresAt      DateTime
  attempts          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
  @@index([otpExpiresAt])
}

// Short-lived password reset tokens. One active row per user (older rows are
// invalidated by setting usedAt on request). Token itself is never stored —
// only a sha256 hash, compared in constant time.
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Short-lived login codes for admin passwordless authentication.
// One row per email at a time (upserted). Deleted on successful verify.
model AdminLoginCode {
  id           String   @id @default(uuid())
  email        String   @unique
  codeHash     String
  expiresAt    DateTime
  attempts     Int      @default(0)
  requestedIp  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiresAt])
}

model CreditPurchase {
  id              String               @id @default(uuid())
  userId          String
  credits         Int
  amount          Decimal              @db.Decimal(10, 2)
  stripeSessionId String               @unique
  status          CreditPurchaseStatus @default(PENDING)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Admin-issued promo codes that grant AI credits when redeemed by a merchant.
// Distinct from `PromoCode` (which is merchant-issued storefront discounts).
model AiCreditCode {
  id              String   @id @default(uuid())
  code            String   @unique
  credits         Int
  // null = unlimited redemptions; otherwise total cap across all users
  maxRedemptions  Int?
  // null = never expires
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  note            String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  redemptions AiCreditCodeRedemption[]

  @@index([code])
}

model AiCreditCodeRedemption {
  id        String   @id @default(uuid())
  codeId    String
  userId    String
  credits   Int
  createdAt DateTime @default(now())

  code AiCreditCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One redemption per user per code
  @@unique([codeId, userId])
  @@index([userId, createdAt])
}
